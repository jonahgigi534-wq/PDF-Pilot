{
  "name": "pdfpilot",
  "productName": "PDFPilot",
  "version": "0.1.0",
  "description": "Free, open-source, offline PDF editor for Windows",
  "license": "MIT",
  "main": "src/main/main.js",
  "scripts": {
    "build": "node scripts/build-renderer.mjs",
    "start": "npm run build && electron .",
    "smoke": "npm run build && electron . --smoke",
    "test": "node test/run-all.mjs",
    "dist": "npm run build && electron-builder --win"
  },
  "devDependencies": {
    "@cantoo/pdf-lib": "^2.7.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.1.200"
  },
  "build": {
    "appId": "org.pdfpilot.app",
    "productName": "PDFPilot",
    "directories": {
      "buildResources": "build-resources",
      "output": "release"
    },
    "files": [
      "src/main/**/*",
      "dist/renderer/**/*",
      "package.json",
      "LICENSE"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build-resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "artifactName": "PDFPilot-Setup-${version}.${ext}",
      "shortcutName": "PDFPilot"
    }
  }
}
